# ============================================================================
# Payway development environment
# ============================================================================
# Copy to `.env` before running `docker compose up`. Never commit `.env`.
# Production secrets belong in your secrets manager, not in a file.

# ----------------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------------
# Local-dev only. docker-compose creates the postgres container with this;
# the backend connects with it. Replace before any non-local deployment.
POSTGRES_PASSWORD=payway_local_dev

# Backend's connection string. Inside docker-compose the host is `postgres`;
# for native dev (cargo run), use `localhost`.
DATABASE_URL=postgres://payway:payway_local_dev@localhost:5432/payway

# ----------------------------------------------------------------------------
# Backend
# ----------------------------------------------------------------------------
PORT=8080

# HMAC-SHA256 key used to verify inbound webhook signatures.
# Generate with:  openssl rand -hex 32
# The placeholder below is for local development only. Anywhere real webhooks
# are received, replace this with a long random value from a secrets manager.
WEBHOOK_SECRET=DEV_ONLY_INSECURE_REPLACE_BEFORE_PROD_a8f5e9c1b2d4

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Examples:
#   payway_backend=debug,tower_http=info,sqlx=warn   (dev)
#   payway_backend=info                              (production)
RUST_LOG=payway_backend=debug,tower_http=info,sqlx=warn
